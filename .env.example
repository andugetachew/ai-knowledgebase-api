# Application
APP_NAME=AI Knowledge Base API
ENVIRONMENT=development

# Security
SECRET_KEY=change_this_to_a_long_random_string_at_least_32_chars

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/ai_knowledgebase_db

# MongoDB
MONGO_URL=mongodb://mongoadmin:mongopassword@localhost:27017
MONGO_DB_NAME=ai_knowledgebase_mongo

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here